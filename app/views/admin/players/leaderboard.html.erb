<table>
  <thead>
    <tr>
      <th>Rank</th>
      <th>Name</th>
      <th>Matches</th>
      <th>Wins</th>
      <th>Losses
    </tr>
  </thead>
  <tbody>
    <% @players.each_with_index do |player, index| %>
      <tr>
        <td><%= index + 1 %></td>
        <td><%= player.name %></td>
        <td><%= player.matches %></td>
        <td><%= player.wins %></td>
        <td><%= player.losses %></td>
      </tr>
    <% end %>
  </tbody>
</table>