<h2>Matches List</h2>

<table class="table table-striped table-hover table-bordered align-middle">
  <thead>
    <tr>
      <th>Team 1</th>
      <th>Team 2</th>
      <th>Match Type</th>
      <th>Winner Team</th>
      <th>Starts At</th>
      <th>Ended At</th>
      <th>Edit</th>
      <th>Delete</th>
    </tr>
  </thead>

  <tbody>
    <% @matches.each do |match| %>
      <tr>
        <td><%= match.team1&.name %></td>
        <td><%= match.team2&.name %></td>
        <td><%= match.match_type&.humanize %></td>
        <td><%= match.winner_team&.name || "-" %></td>
        <td><%= match.started_at&.strftime("%d %b %Y, %I:%M %p") || "-" %></td>
        <td><%= match.ended_at&.strftime("%d %b %Y, %I:%M %p") || "-" %></td>
        <td>
          <%= link_to "Edit", edit_admin_match_path(match), class: "btn btn-sm btn-warning" %>
        </td>
        <td>
          <%= button_to "Delete",
                        admin_match_path(match),
                        method: :delete,
                        data: { turbo_confirm: "Are you sure?" },
                        class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Add New Match", new_admin_match_path, class: "btn btn-primary mt-3" %>